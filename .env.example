# TG Budget Planner — environment variables template (D-06).
#
# Copy this file to .env and fill in real values:
#     cp .env.example .env
#
# .env IS gitignored — NEVER commit real secrets.

# ========================================================================
# Database
# ========================================================================

# Strong password for the `budget` PostgreSQL role. Generate with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSWORD=change_me_strong_password

# SQLAlchemy URLs. In docker-compose these are derived from DB_PASSWORD via
# ${DB_PASSWORD} at compose time, so you only need to set DB_PASSWORD above
# for the docker setup. Set the URLs below explicitly only if you run
# Python directly outside docker (rare in this project).
DATABASE_URL=postgresql+asyncpg://budget:change_me_strong_password@localhost:5432/budget_db
DATABASE_URL_SYNC=postgresql://budget:change_me_strong_password@localhost:5432/budget_db

# ========================================================================
# Telegram Bot (D-04 long-poll)
# ========================================================================

# From @BotFather: /newbot → save the token here.
BOT_TOKEN=1234567890:YOUR_BOT_TOKEN_HERE

# Optional: bot username (without @). Used by Mini App start params.
BOT_USERNAME=your_bot_username_bot

# ========================================================================
# Owner whitelist (AUTH-02)
# ========================================================================

# Your numeric Telegram user ID. Get it from @userinfobot in Telegram.
# All requests with a different tg_user_id will be rejected with 403.
OWNER_TG_ID=123456789

# ========================================================================
# Telegram Mini App
# ========================================================================

# Public URL of the Mini App (must match PUBLIC_DOMAIN below). Set this in
# @BotFather: /setmenubutton → ваш бот → web_app URL.
MINI_APP_URL=https://your-domain.example.com

# ========================================================================
# Internal service-to-service token (INF-04, T-internal mitigation)
# ========================================================================

# Shared secret between bot and api for /api/v1/internal/* calls.
# Generate ONCE per environment with:
#     python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_TOKEN=change_me_generate_with_secrets_token_hex_32

# ========================================================================
# Caddy / TLS (INF-03)
# ========================================================================

# Public domain for Let's Encrypt. DNS A-record must point at this VPS BEFORE
# the first `docker compose up` (Pitfall 4 — ACME challenge requires DNS).
PUBLIC_DOMAIN=your-domain.example.com

# ========================================================================
# Application settings (D-13 logging)
# ========================================================================

APP_TZ=Europe/Moscow
LOG_LEVEL=INFO

# Production: json. Dev: console. docker-compose.override.yml forces console.
LOG_FORMAT=json

# ========================================================================
# Cloudflare Tunnel (production alternative to Let's Encrypt)
# ========================================================================

# Token for cloudflared tunnel — generated via:
#     cloudflared tunnel token tg-budget
# Required only when using docker-compose.cloudflare.yml (Cloudflare Tunnel mode).
CLOUDFLARE_TUNNEL_TOKEN=change_me_cloudflared_tunnel_token

# ========================================================================
# Dev-only — never set DEV_MODE=true in production!
# ========================================================================

# Bypasses HMAC-SHA256 initData validation and injects a mock owner user.
# docker-compose.override.yml sets this automatically for `docker compose up`.
# DEV_MODE=true

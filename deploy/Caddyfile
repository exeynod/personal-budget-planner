# TG Budget Planner — production Caddyfile (INF-03), Let's Encrypt mode.
#
# Caddy auto-HTTPS via Let's Encrypt: requires the configured public domain
# to resolve to this VPS's public IP and ports 80/443 open (Pitfall 4).
# In Cloudflare Tunnel mode (the current production deployment) this file is
# NOT mounted — see Caddyfile.cloudflare instead.
#
# Uses `handle {}` blocks (mutually exclusive, evaluated in written order)
# instead of bare directives — bare directives follow Caddy's default
# directive order, in which `try_files` runs BEFORE `respond` /
# `reverse_proxy` and rewrites unmatched paths to /index.html, masking
# /api/v1/internal/* (which must 403) and /api/* (which must reverse-proxy)
# with the SPA. `handle` short-circuits at the first match.
#
# Source: 01-RESEARCH.md Pattern 10.

{$PUBLIC_DOMAIN} {
	encode zstd gzip

	# T-internal mitigation: 403 for internal endpoints. Must come first so
	# /api/v1/internal/* never reaches the reverse-proxy below. The bot
	# reaches these directly over the budget_net docker network at
	# http://api:8000/... and presents X-Internal-Token (verified by the
	# FastAPI verify_internal_token dependency).
	@internal {
		path /api/v1/internal/*
	}
	handle @internal {
		respond "Forbidden" 403
	}

	# Reverse-proxy the rest of /api/* to FastAPI on the docker network.
	# api container does NOT publish :8000 on the host — only Caddy can
	# reach it (T-internal + T-db-exposure threat model).
	@api {
		path /api/*
	}
	handle @api {
		reverse_proxy api:8000
	}

	# SPA fallback: every other path serves the React app from the
	# frontend_dist named volume mounted at /srv/dist (read-only).
	handle {
		root * /srv/dist
		# Hashed assets are immutable — safe to cache for a year.
		header /assets/* Cache-Control "public, max-age=31536000, immutable"
		# index.html (and SPA fallback) MUST revalidate every load — otherwise
		# the browser/TG WebView keeps a stale shell that points at deleted
		# bundles after a redeploy.
		header / Cache-Control "no-cache"
		header /index.html Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}

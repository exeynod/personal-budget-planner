# TG Budget Planner — dev Caddyfile (HTTP only, no TLS).
#
# Used by docker-compose.dev.yml for local development where there is no
# public DNS and Let's Encrypt cannot issue a cert. Listens on :80 over
# plain HTTP — never deploy this to a public VPS.
#
# Uses `handle {}` blocks for the same reason as Caddyfile / Caddyfile.cloudflare:
# default directive order has `try_files` running before `respond` /
# `reverse_proxy`, which masks /api/* paths with the SPA. `handle` blocks
# are mutually exclusive and evaluated in the written order.
#
# Source: 01-RESEARCH.md Open Question 2 recommendation.

:80 {
	log {
		output stdout
		format console
		level DEBUG
	}
	encode zstd gzip

	@internal {
		path /api/v1/internal/*
	}
	handle @internal {
		respond "Forbidden" 403
	}

	@api {
		path /api/*
	}
	handle @api {
		reverse_proxy api:8000
	}

	handle {
		root * /srv/dist
		# Hashed assets are immutable — safe to cache for a year.
		header /assets/* Cache-Control "public, max-age=31536000, immutable"
		# index.html (and SPA fallback) MUST revalidate every load — otherwise
		# the browser/TG WebView keeps a stale shell that points at deleted
		# bundles after a redeploy.
		header / Cache-Control "no-cache"
		header /index.html Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}

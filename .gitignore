# =====================================================================
# Environment secrets — NEVER commit real values (D-06)
# =====================================================================
.env
.env.local
.env.*.local

# =====================================================================
# Python
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
.venv-*/
venv/
env/

# uv
.uv/

# =====================================================================
# Node / Frontend
# =====================================================================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# =====================================================================
# Docker
# =====================================================================
.dockerignore

# =====================================================================
# IDE & OS
# =====================================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# =====================================================================
# Logs
# =====================================================================
*.log
logs/

# =====================================================================
# Test artifacts
# =====================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
frontend/test-results/
frontend/tests/ui-audit-screenshots/

# =====================================================================
# Claude Code worktree metadata (managed by GSD agents)
# =====================================================================
.claude/worktrees/

# =====================================================================
# Design handoff bundles (Claude Design экспорты — лежат в корне для разбора,
# в репо не пушим — большие и не нужны в истории)
# =====================================================================
*-handoff.zip
*handoff.zip
